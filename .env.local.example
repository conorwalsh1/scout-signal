# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Admin: email of the admin user (sign up via app, then set here). Admin sees all companies and can delete.
ADMIN_EMAIL=

# Cron: secret for /api/cron/ingest (Vercel Cron sends Authorization: Bearer <CRON_SECRET>). Optional locally.
CRON_SECRET=

# Stripe (optional for Pro)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
